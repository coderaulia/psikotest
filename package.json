{
  "name": "psikotest-frontend",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:full": "concurrently -n web,api -c cyan,green \"npm run dev\" \"npm run dev:api\"",
    "build": "tsc --noEmit && vite build",
    "build:hostinger-web": "npm run build",
    "build:api": "npm --prefix apps/api run build",
    "build:hostinger-api": "npm --prefix apps/api run build",
    "package:api-deploy": "powershell -ExecutionPolicy Bypass -File scripts/package-api-deploy.ps1",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "npm --prefix apps/api run typecheck",
    "test": "node -e \"console.log('No frontend tests wired yet.')\"",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.3.1"
  }
}
